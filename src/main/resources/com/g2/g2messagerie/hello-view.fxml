<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller=""
            styleClass="root-chat"
            prefWidth="900" prefHeight="620">

    <!-- ===== BARRE DU HAUT ===== -->
    <top>
        <HBox styleClass="topbar" alignment="CENTER_LEFT" spacing="12">
            <Label text="💬" styleClass="topbar-icon"/>
            <Label text="Messagerie Association" styleClass="topbar-title"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Label fx:id="connectedUserLabel" styleClass="topbar-user"/>
            <Button text="📋 Membres" fx:id="listMembersBtn"
                    styleClass="btn-outline" onAction="#handleListMembers"/>
            <Button text="🚪 Déconnexion" styleClass="btn-logout"
                    onAction="#handleLogout"/>
        </HBox>
    </top>

    <!-- ===== PANNEAU GAUCHE — liste des membres ===== -->
    <left>
        <VBox styleClass="sidebar" prefWidth="220" spacing="8">
            <Label text="Membres" styleClass="sidebar-title"/>
            <ListView fx:id="membersList" styleClass="members-list" VBox.vgrow="ALWAYS"
                      onMouseClicked="#handleSelectMember"/>
        </VBox>
    </left>

    <!-- ===== CENTRE — zone de chat ===== -->
    <center>
        <VBox styleClass="chat-area">

            <!-- Titre de la conversation -->
            <HBox styleClass="chat-header" alignment="CENTER_LEFT">
                <Label fx:id="currentChatLabel" text="Sélectionnez un membre"
                       styleClass="chat-header-label"/>
            </HBox>

            <!-- Messages -->
            <ScrollPane fx:id="messagesScrollPane" styleClass="messages-scroll"
                        fitToWidth="true" VBox.vgrow="ALWAYS">
                <VBox fx:id="messagesBox" styleClass="messages-box" spacing="6"/>
            </ScrollPane>

            <!-- Barre de statut -->
            <Label fx:id="statusLabel" styleClass="status-bar" wrapText="true"/>

            <!-- Zone de saisie -->
            <HBox styleClass="input-bar" spacing="8" alignment="CENTER">
                <TextField fx:id="messageField" promptText="Écrivez votre message..."
                           styleClass="message-input" HBox.hgrow="ALWAYS"
                           onKeyPressed="#handleEnterKey"/>
                <Button text="Envoyer ➤" styleClass="btn-send" onAction="#handleSendMessage"/>
            </HBox>

        </VBox>
    </center>

</BorderPane>
